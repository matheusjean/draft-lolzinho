{
  "name": "sorteio-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "seed": "ts-node --project tsconfig.json --transpile-only prisma/seed.ts",
    "seed:match:yesterday": "ts-node --project tsconfig.json --transpile-only prisma/seed-yesterday-match.ts",
    "seed:match:extra-2026-04-13": "ts-node --project tsconfig.json --transpile-only prisma/seed-extra-match-2026-04-13.ts",
    "backfill:players": "ts-node --project tsconfig.json --transpile-only prisma/backfill-player-history.ts",
    "postinstall": "prisma generate",
    "vercel-build": "npm run prisma:generate && npm run build"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.json --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.19",
    "@prisma/client": "^6.19.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
