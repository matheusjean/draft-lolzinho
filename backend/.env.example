DATABASE_URL="postgres://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgres://USER:PASSWORD@HOST:PORT/DATABASE"
# If your Vercel integration only provides prefixed variables like
# draft_PRISMA_DATABASE_URL / draft_DATABASE_URL / draft_POSTGRES_URL,
# the project now falls back to them automatically in runtime and Prisma CLI.
NODE_ENV="development"
JWT_SECRET="troque-por-um-segredo-forte"
JWT_EXPIRES_IN="7d"
LOGIN_CODE_TTL_MINUTES="15"
CORS_ORIGIN="http://localhost:5173"
PORT="3333"
