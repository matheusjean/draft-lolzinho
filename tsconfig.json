{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "api/**/*",
    "src/**/*",
    "backend/api/**/*",
    "backend/src/**/*"
  ]
}
